  <Code>Function IsChecked(ByVal val As String) As String 
  Dim isTrue As Boolean= Convert.ToBoolean(val)
      If isTrue  Then
          Return "X"
     Else
          Return ""
     End If
End Function

Function IsNo(ByVal val As String) As String 
  Dim isTrue As Boolean = Convert.ToBoolean(val)
      If isTrue &lt;&gt; true  Then
          Return "X"
     Else
          Return ""
     End If
End Function</Code>
